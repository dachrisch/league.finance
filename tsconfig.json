{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "paths": {
      "@client/*": ["src/client/*"],
      "@shared/*": ["shared/*"]
    }
  },
  "include": ["src/client/**/*", "shared/**/*", "vite.config.ts", "index.html"],
  "exclude": ["src/client/**/__tests__/**", "src/**/*.test.ts", "src/**/*.test.tsx", "shared/**/__tests__/**"]
}
