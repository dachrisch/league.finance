{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "baseUrl": ".",
    "types": ["vitest/globals"],
    "paths": {
      "@shared/*": ["shared/*"]
    }
  },
  "include": ["src/server/**/*", "shared/**/*"],
  "exclude": ["src/server/**/__tests__/**", "src/**/*.test.ts", "shared/**/__tests__/**"]
}
